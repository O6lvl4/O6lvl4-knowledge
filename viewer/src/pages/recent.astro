---
import { getCollection } from 'astro:content';
import Base from '@o6lvl4/graph-garden/layouts/Base.astro';
import { slugify } from '@o6lvl4/graph-garden';

const allNotes = await getCollection('notes');
const notes = allNotes.filter(
  (n) => n.id !== 'index' && n.id !== 'dashboard' && n.data.public !== false
);

function toDateStr(d: string | Date | undefined): string {
  if (!d) return '';
  if (d instanceof Date) return d.toISOString().slice(0, 10);
  return String(d);
}

const sorted = notes.sort((a, b) => {
  const da = toDateStr(a.data.updated_at) || toDateStr(a.data.created_at) || '';
  const db = toDateStr(b.data.updated_at) || toDateStr(b.data.created_at) || '';
  return db.localeCompare(da);
});

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Base title="Recent" ogType="website" canonicalPath="/recent">
  <div class="note-list">
    <h2>Recent Notes</h2>
    <p class="subtitle">{notes.length} notes, sorted by last updated</p>
    {
      sorted.map((note) => (
        <a href={`${base}notes/${slugify(note.id)}`} class="note-card">
          <span class="title">{note.data.title || note.id}</span>
          <span class="meta">
            <span class="date">{toDateStr(note.data.updated_at) || toDateStr(note.data.created_at)}</span>
            {(note.data.tags || []).map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </span>
        </a>
      ))
    }
  </div>
</Base>

<style>
  .subtitle {
    color: var(--fg-muted, #8b949e);
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .date {
    color: var(--fg-muted, #8b949e);
    font-size: 0.8rem;
    font-family: monospace;
    margin-right: 0.5rem;
  }
</style>
