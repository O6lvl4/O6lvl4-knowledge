---
import { getCollection } from 'astro:content';
import { execSync } from 'node:child_process';
import Base from '@o6lvl4/graph-garden/layouts/Base.astro';
import { slugify } from '@o6lvl4/graph-garden';

const allNotes = await getCollection('notes');
const notes = allNotes.filter(
  (n) => n.id !== 'index' && n.id !== 'dashboard' && n.data.public !== false
);

// git log で各ファイルの最終コミット日時を取得
const vaultDir = new URL('../../vault/', import.meta.url).pathname;
const gitTimestamps = new Map<string, string>();
for (const note of notes) {
  try {
    const ts = execSync(
      `git log -1 --format=%cI -- "${vaultDir}${note.id}.md"`,
      { encoding: 'utf-8', cwd: vaultDir }
    ).trim();
    if (ts) gitTimestamps.set(note.id, ts);
  } catch { /* ignore */ }
}

const sorted = notes.sort((a, b) => {
  const da = gitTimestamps.get(a.id) || '';
  const db = gitTimestamps.get(b.id) || '';
  return db.localeCompare(da);
});

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

function formatTimestamp(id: string): string {
  const ts = gitTimestamps.get(id);
  if (!ts) return '';
  const d = new Date(ts);
  const pad = (n: number) => String(n).padStart(2, '0');
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
}
---

<Base title="Recent" ogType="website" canonicalPath="/recent">
  <div class="note-list">
    <h2>Recent Notes</h2>
    <p class="subtitle">{notes.length} notes, sorted by last git commit</p>
    {
      sorted.map((note) => (
        <a href={`${base}notes/${slugify(note.id)}`} class="note-card">
          <span class="title">{note.data.title || note.id}</span>
          <span class="meta">
            <span class="date">{formatTimestamp(note.id)}</span>
            {(note.data.tags || []).map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </span>
        </a>
      ))
    }
  </div>
</Base>

<style>
  .subtitle {
    color: var(--fg-muted, #8b949e);
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .date {
    color: var(--fg-muted, #8b949e);
    font-size: 0.8rem;
    font-family: monospace;
    margin-right: 0.5rem;
  }
</style>
