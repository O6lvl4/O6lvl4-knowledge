---
import { getCollection } from 'astro:content';
import Base from '@o6lvl4/graph-garden/layouts/Base.astro';
import { slugify } from '@o6lvl4/graph-garden';

const allNotes = await getCollection('notes');
const notes = allNotes.filter(
  (n) => n.id !== 'index' && n.id !== 'dashboard' && n.data.public !== false
);

// Parse to a full Date so notes sharing a calendar day still order by time.
// Date-only frontmatter (YYYY-MM-DD) parses to midnight; timestamped notes
// (YYYY-MM-DDTHH:mm:ss+09:00) keep their time and sort correctly within a day.
function toDate(v: string | Date | undefined): Date | null {
  if (!v) return null;
  const d = v instanceof Date ? v : new Date(v);
  return Number.isNaN(d.getTime()) ? null : d;
}

// Display only the calendar day. Prefer the authored string prefix to avoid a
// UTC off-by-one near midnight; fall back to ISO for Date objects.
function toDisplayDate(v: string | Date | undefined): string {
  if (!v) return '';
  if (typeof v === 'string') return v.slice(0, 10);
  return v.toISOString().slice(0, 10);
}

function sortValue(note: (typeof notes)[number]): number {
  const d = toDate(note.data.updated_at) ?? toDate(note.data.created_at);
  return d ? d.getTime() : 0;
}

const sorted = notes.sort((a, b) => sortValue(b) - sortValue(a));

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const noteData = sorted.map((note) => ({
  href: `${base}notes/${slugify(note.id)}`,
  title: note.data.title || note.id,
  date: toDisplayDate(note.data.updated_at) || toDisplayDate(note.data.created_at),
  sort: sortValue(note),
  tags: (note.data.tags || []) as string[],
}));
---

<Base title="Recent" ogType="website" canonicalPath="/recent">
  <div class="note-list">
    <div class="recent-header">
      <h2>Recent Notes</h2>
      <button id="sort-toggle" class="sort-btn" data-order="desc" title="Sort order">
        <span class="sort-label">New → Old</span>
        <span class="sort-icon">↓</span>
      </button>
    </div>
    <p class="subtitle">{notes.length} notes</p>
    <div id="note-container">
      {noteData.map((note) => (
        <a href={note.href} class="note-card" data-date={note.date} data-sort={note.sort}>
          <span class="title">{note.title}</span>
          <span class="meta">
            <span class="date">{note.date}</span>
            {note.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </span>
        </a>
      ))}
    </div>
  </div>
</Base>

<script>
  const btn = document.getElementById('sort-toggle')!;
  const container = document.getElementById('note-container')!;
  const label = btn.querySelector('.sort-label')!;
  const icon = btn.querySelector('.sort-icon')!;

  btn.addEventListener('click', () => {
    const current = btn.dataset.order;
    const next = current === 'desc' ? 'asc' : 'desc';
    btn.dataset.order = next;
    label.textContent = next === 'desc' ? 'New → Old' : 'Old → New';
    icon.textContent = next === 'desc' ? '↓' : '↑';

    const cards = [...container.querySelectorAll('.note-card')] as HTMLElement[];
    cards.sort((a, b) => {
      const ta = Number(a.dataset.sort || '0');
      const tb = Number(b.dataset.sort || '0');
      return next === 'desc' ? tb - ta : ta - tb;
    });
    for (const card of cards) container.appendChild(card);
  });
</script>

<style>
  .recent-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .recent-header h2 {
    margin: 0;
  }
  .sort-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--border, #30363d);
    border-radius: 6px;
    background: var(--bg-secondary, #161b22);
    color: var(--fg-muted, #8b949e);
    font-size: 0.8rem;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .sort-btn:hover {
    border-color: var(--fg-muted, #8b949e);
    color: var(--fg, #c9d1d9);
  }
  .sort-icon {
    font-size: 0.9rem;
  }
  .subtitle {
    color: var(--fg-muted, #8b949e);
    margin-top: 0.25rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .date {
    color: var(--fg-muted, #8b949e);
    font-size: 0.8rem;
    font-family: monospace;
    margin-right: 0.5rem;
  }
</style>
